# ── Environment switch ──────────────────────────────────────────────────────
# 'demo' = Kalshi sandbox (no real liquidity)
# 'prod' = Kalshi production (real orderbooks; paper-only unless LIVE_TRADING=true)
KALSHI_ENV=demo

# ── Trading mode ────────────────────────────────────────────────────────────
# false = paper trading only (orders simulated, no real money)
# true  = live trading (REAL MONEY — only flip after backtest gate passes)
LIVE_TRADING=false

# ── Kalshi credentials (DEMO) ───────────────────────────────────────────────
KALSHI_API_KEY_ID_DEMO=
KALSHI_PRIVATE_KEY_PATH_DEMO=./secrets/kalshi_demo.pem

# ── Kalshi credentials (PROD) ───────────────────────────────────────────────
KALSHI_API_KEY_ID_PROD=
KALSHI_PRIVATE_KEY_PATH_PROD=./secrets/kalshi_prod.pem

# ── Kalshi endpoints ────────────────────────────────────────────────────────
# These should NOT need to change. The bot picks demo vs prod URLs from KALSHI_ENV.
KALSHI_REST_BASE_URL_DEMO=https://demo-api.kalshi.co/trade-api/v2
KALSHI_WS_URL_DEMO=wss://demo-api.kalshi.co/trade-api/ws/v2
KALSHI_REST_BASE_URL_PROD=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL_PROD=wss://api.elections.kalshi.com/trade-api/ws/v2

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console

# ── Phase 1+ (DB, backtest) ─────────────────────────────────────────────────
# DB_PATH=./data/kalshi.db
# BACKTEST_START=
# BACKTEST_END=

# ── Phase 2+ (WebSocket) ────────────────────────────────────────────────────
# WS_RECONNECT_MAX=5
# WS_PING_INTERVAL=30

# ── Phase 4+ (execution) ────────────────────────────────────────────────────
# MAX_POSITION_SIZE_CENTS=10000
# MAX_OPEN_ORDERS=20
# KILL_SWITCH_PATH=./KILL