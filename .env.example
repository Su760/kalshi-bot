# ── Kalshi credentials ──────────────────────────────────────────────────────
KALSHI_ENV=demo
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_demo.pem
KALSHI_REST_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_WS_URL=wss://demo-api.kalshi.co/trade-api/ws/v2

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console

# ── Phase 1+ (DB, backtest) — leave blank until Phase 1 ────────────────────
# DB_PATH=./data/kalshi.db
# BACKTEST_START=
# BACKTEST_END=

# ── Phase 2+ (WebSocket) ─────────────────────────────────────────────────────
# WS_RECONNECT_MAX=5
# WS_PING_INTERVAL=30

# ── Phase 4+ (execution) ─────────────────────────────────────────────────────
# MAX_POSITION_SIZE_CENTS=10000
# MAX_OPEN_ORDERS=20
# KILL_SWITCH_PATH=./KILL
